<header class="report-header">
    
    <div class="header-left-group">
        <div class="conditional-header" 
             th:if="${not #strings.isEmpty(dynamicData)}" 
             th:text="${dynamicData}">
             Conditional Header Content (Disappears if empty)
        </div>
        
        <h1 class="main-header" th:text="${REPORT_MODEL.getPageTitle()}">
            Main Header Title
        </h1>
        
        <h2 class="sub-header" th:text="${REPORT_MODEL.getPageSubTitle()}">
            Sub Header Information
        </h2>
    </div>

    <div class="header-right-group">
        <p class="meta-item font-bold" th:text="${currentUser.name}">
            John Doe
        </p>
        <p class="meta-item text-muted" th:text="${#calendars.format(#calendars.createNow(), 'dd-MM-yyyy')}">
            30-05-2026
        </p>
    </div>

</header>




.report-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end; /* Anchors the baselines of both sides to the bottom */
    width: 100%;
    padding: 20px 0;
    border-bottom: 1px solid #ccc;
    font-family: Arial, sans-serif;
}

/* LEFT COLUMN CONFIGURATION */
.header-left-group {
    display: flex;
    flex-direction: column; /* Stacks headers vertically */
    justify-content: flex-end;
    flex-grow: 1;
}

.conditional-header {
    font-size: 12px;
    color: #555;
    margin-bottom: 4px; /* Space above main title */
}

.main-header {
    font-size: 20px;
    font-weight: bold;
    margin: 0 0 4px 0;
    line-height: 1.2;
}

.sub-header {
    font-size: 14px;
    font-weight: normal;
    color: #333;
    margin: 0;
}

/* RIGHT COLUMN CONFIGURATION */
.header-right-group {
    display: flex;
    flex-direction: column; /* Stacks user and date vertically */
    align-items: flex-end;   /* Right-aligns the text within the column */
    flex-shrink: 0;          /* Keeps it from squishing */
    margin-left: 20px;
}

.meta-item {
    font-size: 12px;
    margin: 0;
    line-height: 1.4;
}

.font-bold { font-weight: bold; }
.text-muted { color: #666; }
