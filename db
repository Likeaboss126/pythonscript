#!/bin/bash

# 1. Quick pre-scan to find the total count
echo "Counting files... please wait."
grand_total_files=$(find . -type f -name "*.jrxml" | wc -l)

if [ "$grand_total_files" -eq 0 ]; then
    echo "No .jrxml files found in this directory or subdirectories."
    exit 0
fi

echo "=========================================================================================="
echo "          RECURSIVE JASPERREPORTS 6 COMPONENT ANALYSIS REPORT                             "
echo "=========================================================================================="
printf "%-12s | %-45s | %-4s | %-4s | %-4s | %-4s | %-4s | %-4s\n" "Progress" "File Path (Relative)" "Txt" "Fld" "Tbl" "Crt" "Sub" "Frm"
echo "------------------------------------------------------------------------------------------"

# Initialize Global Counters
current_file_index=0
total_static_text=0
total_text_fields=0
total_tables=0
total_charts=0
total_subreports=0
total_images=0
total_frames=0

# Layout Band Counters
total_page_headers=0
total_page_footers=0
total_column_headers=0
total_column_footers=0

# Use 'find' to locate all .jrxml files recursively from the current directory (.)
while IFS= read -r file; do
    [ -f "$file" ] || continue
    ((current_file_index++))

    # 1. Text Elements
    static_text=$(grep -c "<staticText" "$file")
    text_fields=$(grep -c "<textField" "$file")

    # 2. Complex & Layout Elements (Handles optional 'jr:' namespace)
    tables=$(grep -E -c "<(jr:)?table" "$file")
    lists=$(grep -E -c "<(jr:)?list" "$file")
    actual_tables=$((tables + lists))

    # 3. Graphical Elements (Standard Jasper 6 Chart Types and Images)
    charts=$(grep -E -c "<(pie|bar|line|area|bubble|candlestick|highLow|multiAxis|scatter|stacked|timeSeries|gantt)?Chart" "$file")
    images=$(grep -c "<image" "$file")

    # 4. Advanced/Structural Elements
    subreports=$(grep -c "<subreport" "$file")
    crosstabs=$(grep -c "<crosstab" "$file")
    frames=$(grep -c "<frame" "$file")
    
    # 5. Document Structure Bands
    page_header=$(grep -c "<pageHeader" "$file")
    page_footer=$(grep -c "<pageFooter" "$file")
    col_header=$(grep -c "<columnHeader" "$file")
    col_footer=$(grep -c "<columnFooter" "$file")

    # Add to Running Global Totals
    ((total_static_text += static_text))
    ((total_text_fields += text_fields))
    ((total_tables += actual_tables))
    ((total_charts += charts))
    ((total_subreports += subreports))
    ((total_images += images))
    ((total_frames += frames))
    
    ((total_page_headers += page_header))
    ((total_page_footers += page_footer))
    ((total_column_headers += col_header))
    ((total_column_footers += col_footer))

    # Flag complex files for quick identification in the live view
    alert=""
    if [ "$actual_tables" -gt 0 ]; then alert="${alert}[TABLES] "; fi
    if [ "$charts" -gt 0 ]; then alert="${alert}[CHARTS] "; fi
    if [ "$subreports" -gt 0 ]; then alert="${alert}[SUBREPORTS] "; fi

    # Clean up the display path name if it is too long
    if [ ${#file} -gt 45 ]; then
        display_path="...${file: -42}"
    else
        display_path="$file"
    fi

    # Create progress string, e.g., "[12/250]"
    progress_str="[$current_file_index/$grand_total_files]"

    printf "%-12s | %-45s | %-4d | %-4d | %-4d | %-4d | %-4d | %-4d %s\n" \
        "$progress_str" "$display_path" "$static_text" "$text_fields" "$actual_tables" "$charts" "$subreports" "$frames" "$alert"

done < <(find . -type f -name "*.jrxml" | sort)

echo "=========================================================================================="
echo "   COMPLETE GLOBAL SUMMARY INVENTORY (ALL SUBFOLDERS)"
echo "=========================================================================================="
echo " Total JRXML Files Scanned : $current_file_index out of $grand_total_files"
echo "------------------------------------------------------------------------------------------"
echo " NATIVE COMPONENT COUNTS:"
echo "  • Total Static Text Elements (<staticText>)   : $total_static_text"
echo "  • Total Dynamic Text Fields (<textField>)     : $total_text_fields"
echo "  • Total Layout Frames (<frame>)               : $total_frames"
echo "  • Total Image Elements (<image>)              : $total_images"
echo "  • Total Tables/Lists Found                    : $total_tables"
echo "  • Total Charts Found                          : $total_charts"
echo "  • Total Subreports Found                      : $total_subreports"
echo "------------------------------------------------------------------------------------------"
echo " STRUCTURAL TEMPLATE BANDS FOUND:"
echo "  • Total Page Headers (<pageHeader>)           : $total_page_headers"
echo "  • Total Page Footers (<pageFooter>)           : $total_page_footers"
echo "  • Total Column Headers (<columnHeader>)       : $total_column_headers"
echo "  • Total Column Footers (<columnFooter>)       : $total_column_footers"
echo "=========================================================================================="
