import java.io.ByteArrayInputStream;
import java.io.ByteArrayOutputStream;
import java.io.IOException;
import java.util.ArrayList;
import java.util.List;

import org.apache.pdfbox.Loader;
import org.apache.pdfbox.contentstream.operator.Operator;
import org.apache.pdfbox.cos.COSName;
import org.apache.pdfbox.pdfparser.PDFStreamParser;
import org.apache.pdfbox.pdfwriter.ContentStreamWriter;
import org.apache.pdfbox.pdmodel.PDDocument;
import org.apache.pdfbox.pdmodel.PDPage;
import org.apache.pdfbox.pdmodel.common.PDStream;

public class PdfArtifactFixer {

    public static byte[] fixArtifacts(byte[] pdfBytes) throws IOException {

        PDDocument document = Loader.loadPDF(pdfBytes);

        PDPage page = document.getPage(0);

        PDFStreamParser parser = new PDFStreamParser(page);

        List<Object> tokens = new ArrayList<>();

Object token;

while ((token = parser.parseNextToken()) != null) {
    tokens.add(token);
}

        List<Object> updatedTokens = new ArrayList<>();

        for (Object token : tokens) {

            updatedTokens.add(token);

            if (token instanceof Operator) {

                Operator op = (Operator) token;

                String name = op.getName();

                // Border/vector drawing operators
                if ("S".equals(name)
                        || "s".equals(name)
                        || "f".equals(name)
                        || "B".equals(name)) {

                    // Wrap as Artifact
                    updatedTokens.add(
                            updatedTokens.size() - 1,
                            COSName.getPDFName("Artifact")
                    );

                    updatedTokens.add(
                            updatedTokens.size() - 1,
                            Operator.getOperator("BMC")
                    );

                    updatedTokens.add(
                            Operator.getOperator("EMC")
                    );
                }
            }
        }

        ByteArrayOutputStream output = new ByteArrayOutputStream();

        ContentStreamWriter writer =
                new ContentStreamWriter(output);

        writer.writeTokens(updatedTokens);

        PDStream newStream =
                new PDStream(document,
                        new ByteArrayInputStream(
                                output.toByteArray()));

        page.setContents(newStream);

        ByteArrayOutputStream finalPdf =
                new ByteArrayOutputStream();

        document.save(finalPdf);

        document.close();

        return finalPdf.toByteArray();
    }
}
