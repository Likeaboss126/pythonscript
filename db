import java.io.ByteArrayOutputStream;
import java.io.IOException;
import java.util.ArrayList;
import java.util.List;

import org.apache.pdfbox.Loader;
import org.apache.pdfbox.contentstream.operator.Operator;
import org.apache.pdfbox.cos.COSName;
import org.apache.pdfbox.pdfwriter.ContentStreamWriter;
import org.apache.pdfbox.pdfparser.PDFStreamParser;
import org.apache.pdfbox.pdmodel.PDDocument;
import org.apache.pdfbox.pdmodel.PDPage;

public class PdfArtifactMarker {

    public static byte[] artifactPaths(byte[] pdfBytes) throws IOException {

        PDDocument document = Loader.loadPDF(pdfBytes);

        for (PDPage page : document.getPages()) {

            PDFStreamParser parser = new PDFStreamParser(page);

            List<Object> tokens = parser.parseTokens();

            List<Object> newTokens = new ArrayList<>();

            boolean artifactOpened = false;

            for (Object token : tokens) {

                if (token instanceof Operator) {

                    Operator op = (Operator) token;

                    String name = op.getName();

                    // Path painting operators
                    boolean isPathPaintOperator =
                            "S".equals(name) ||
                            "s".equals(name) ||
                            "f".equals(name) ||
                            "F".equals(name) ||
                            "f*".equals(name) ||
                            "B".equals(name) ||
                            "B*".equals(name) ||
                            "b".equals(name) ||
                            "b*".equals(name);

                    if (isPathPaintOperator) {

                        // Begin Artifact
                        if (!artifactOpened) {

                            newTokens.add(COSName.getPDFName("Artifact"));
                            newTokens.add(Operator.getOperator("BMC"));

                            artifactOpened = true;
                        }

                        newTokens.add(token);

                        // End Artifact
                        newTokens.add(Operator.getOperator("EMC"));

                        artifactOpened = false;

                        continue;
                    }
                }

                newTokens.add(token);
            }

            ByteArrayOutputStream updatedStream = new ByteArrayOutputStream();

            ContentStreamWriter writer =
                    new ContentStreamWriter(updatedStream);

            writer.writeTokens(newTokens);

            page.setContents(
                    new org.apache.pdfbox.pdmodel.common.PDStream(
                            document,
                            new java.io.ByteArrayInputStream(
                                    updatedStream.toByteArray()
                            )
                    )
            );
        }

        ByteArrayOutputStream baos = new ByteArrayOutputStream();

        document.save(baos);

        document.close();

        return baos.toByteArray();
    }
}
