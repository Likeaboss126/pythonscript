<!DOCTYPE html>
<html lang="en" xmlns:th="http://www.thymeleaf.org">
<head>
    <meta charset="UTF-8"/>
    <title>Your Current Assets and Liabilities</title>
    <style>
        @page {
            size: A4 landscape;
            margin: 15mm;
        }

        body {
            font-family: 'NotoSans', sans-serif;
            color: #111111;
            margin: 0;
            background-color: #ffffff;
        }

        /* --- Structural Presentation Layout Styling --- */
        .layout-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            border: none;
        }

        .layout-table td {
            padding: 0;
            vertical-align: top;
            border: none;
        }

        .left-align-cell {
            width: 65%;
            text-align: left;
        }

        .right-align-cell {
            width: 35%;
            text-align: right;
            padding-top: 15px; /* Visual baseline alignment */
        }

        /* --- Header Text Styles --- */
        .header-context { 
            font-size: 11px; 
            font-weight: bold; 
            color: #555555; 
            margin: 0 0 5px 0; 
        }
        
        h1 { 
            font-size: 26px; 
            font-weight: normal; 
            margin: 0; 
            color: #222222; 
        }
        
        .meta-text { 
            font-size: 13px; 
            font-weight: bold; 
            margin: 0; 
        }
        
        .meta-date { 
            font-size: 12px; 
            color: #555555; 
            margin: 2px 0 0 0; 
        }

        /* --- Financial Data Matrix Styles --- */
        .financial-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }
        
        .financial-table thead th {
            color: #111111;
            padding: 10px 4px;
            text-align: right;
            border-bottom: 4px solid #222222; /* Thick column header line */
        }
        
        .financial-table th.metric-column,
        .financial-table td.metric-column {
            text-align: left;
        }
        
        .financial-table td {
            padding: 8px 4px;
            border-bottom: 1px solid #e0e0e0;
        }
    </style>
</head>
<body>

    <table class="layout-table" role="presentation">
        <tr>
            <td class="left-align-cell">
                <p class="header-context">Details</p>
                <h1>Your current assets and liabilities</h1>
            </td>
            <td class="right-align-cell">
                <p class="meta-text">M. and J. Vollenweider</p>
                <p class="meta-date">22 May 2026</p>
            </td>
        </tr>
    </table>

    <table class="financial-table">
        <thead>
            <tr>
                <th scope="col" class="metric-column">Year</th>
                <th scope="col">2026</th>
                <th scope="col">2027</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td class="metric-column">Age of (Palle New-Ret_TEST-DATA)</td>
                <td>36</td>
                <td>37</td>
            </tr>
        </tbody>
    </table>

</body>
</html>
