<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<body>

<div th:fragment="timelineComponent(items)">

    <style>
        .timeline-container {
            position: relative;
            width: 100%;
            box-sizing: border-box;
        }
        .timeline-row {
            display: flex;
            align-items: flex-start;
            position: relative;
            margin-bottom: 24px;
        }
        .column-year {
            width: 45px;
            font-weight: 700;
            font-size: 0.85rem;
            color: #111827;
            text-align: right;
            padding-top: 8px;
        }
        .column-icon {
            margin: 0 16px;
            position: relative;
            z-index: 10;
        }
        .circle-container {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 1px solid #9ca3af;
            background-color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }
        .column-details {
            flex: 1;
            padding-top: 4px;
        }
        .event-title {
            margin: 0;
            font-size: 0.875rem;
            font-weight: 600;
            color: #111827;
            line-height: 1.3;
        }
        .event-amount {
            margin: 2px 0 0 0;
            font-size: 0.8rem;
            font-weight: 700;
        }
        .text-green { color: #16a34a; }
        .text-gray { color: #4b5563; }

        /* Tracks line inside individual parent rows */
        .vertical-line {
            position: absolute;
            top: 36px;
            left: 78px; /* Centers the track perfectly beneath the circle */
            width: 2px;
            background-color: #d1d5db;
            height: calc(100% + 24px);
            z-index: 1;
        }
    </style>

    <div class="timeline-container">
        <div th:each="item, iterStat : ${items}" class="timeline-row">

            <div th:if="${item.hasLine}" class="vertical-line"></div>

            <div class="column-year">
                <span th:text="${item.year}">2033</span>
            </div>

            <div class="column-icon">
                <div class="circle-container">
                    <span th:if="${item.name.contains('estate') or item.name.contains('mortgage')}">🏠</span>
                    <span th:if="${item.name.contains('travel')}">✈️</span>
                    <span th:if="${item.name.contains('payout') or item.name.contains('pension')}">💰</span>
                </div>
            </div>

            <div class="column-details">
                <h3 class="event-title" th:text="${item.name}">Event Name</h3>
                <p class="event-amount"
                   th:classappend="${item.isValueGreen} ? 'text-green' : 'text-gray'"
                   th:text="${item.amount}">
                    0.00 CHF
                </p>
            </div>

        </div>
    </div>

</div>

</body>
</html>
