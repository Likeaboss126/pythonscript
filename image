String rawSvgString = VectorChartExporter.convertDrawableToRawSvg((Drawable) baseProjectChart, 727, 330);
model.addAttribute("chartSvg", rawSvgString);


public static String convertDrawableToRawSvg(Drawable drawable, int targetWidth, int targetHeight) {
    try {
        SVGGraphics2D svg2d = new SVGGraphics2D(targetWidth, targetHeight);
        
        // Optional: Ensure point alignment
        svg2d.setShapeUnits(SVGUnits.PT);
        svg2d.setTextUnits(SVGUnits.PT);

        Rectangle2D area = new Rectangle2D.Double(0, 0, targetWidth, targetHeight);
        drawable.draw(svg2d, area);

        // Just return the raw XML text string straight out!
        return svg2d.getSVGElement(); 

    } catch (Exception e) {
        throw new RuntimeException("Failed compiling raw SVG string", e);
    }
}


<div class="chart-container" style="width: 727pt; height: 330pt; margin: 0 auto;">
    
    <div th:utext="${chartSvg}" style="width: 727pt; height: 330pt;"></div>

</div>
