public String convertDrawableToBase64(Drawable drawable, int width, int height) {
        try {
            // 1. Create an in-memory blank canvas matching your targeted report layout dimensions
            BufferedImage image = new BufferedImage(width, height, BufferedImage.TYPE_INT_ARGB);
            Graphics2D g2 = image.createGraphics();
            
            // 2. Force the JCommon Drawable component to paint its vector graphics onto our canvas
            java.awt.geom.Rectangle2D area = new java.awt.geom.Rectangle2D.Double(0, 0, width, height);
            drawable.draw(g2, area);
            g2.dispose(); // Free up system graphics resources immediately

            // 3. Compress the raw bitmap canvas down into a standard PNG byte stream
            ByteArrayOutputStream baos = new ByteArrayOutputStream();
            ImageIO.write(image, "png", baos);
            byte[] imageBytes = baos.toByteArray();

            // 4. Encode the raw binary bytes into a clean, text-safe Base64 string
            return Base64.getEncoder().encodeToString(imageBytes);

        } catch (Exception e) {
            throw new RuntimeException("Failed to render JCommonDrawable to base64 string", e);
        }
    }
