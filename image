import io.github.openhtmltopdf.extend.FSObjectDrawer;
import io.github.openhtmltopdf.extend.OutputDevice;
import org.w3c.dom.Element;
import org.jfree.chart.ui.Drawable;
import java.awt.Graphics2D;
import java.awt.RenderingHints;
import java.awt.geom.Rectangle2D;
import java.util.Map;

public class DynamicChartDrawer implements FSObjectDrawer {
    
    private final Map<String, Drawable> chartMap;

    public DynamicChartDrawer(Map<String, Drawable> chartMap) {
        this.chartMap = chartMap;
    }

    // THE CORRECT METHOD SIGNATURE OVERRIDE
    @Override
    public void drawObject(Element e, double x, double y, double width, double height, 
                           OutputDevice device, io.github.openhtmltopdf.render.RenderingContext context) {
        
        // 1. Fetch the identifier attribute from your HTML tag
        String chartKey = e.getAttribute("data-chart-key");
        Drawable chartDrawable = chartMap.get(chartKey);
        
        if (chartDrawable != null) {
            // 2. THE CORRECT GRAPHICS GETTER: Get the native Graphics2D pipeline
            Graphics2D g2d = device.getGraphics2D();
            
            // 3. Set crisp rendering setups directly onto the PDF canvas context
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            g2d.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON);
            g2d.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);
            g2d.setRenderingHint(RenderingHints.KEY_STROKE_CONTROL, RenderingHints.VALUE_STROKE_PURE);

            // 4. Draw the chart using the exact physical coordinates passed by the layout engine
            Rectangle2D area = new Rectangle2D.Double(x, y, width, height);
            chartDrawable.draw(g2d, area);
        }
    }
}
