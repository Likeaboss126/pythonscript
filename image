import io.github.openhtmltopdf.extend.FSUserAgentCallback;
import org.jfree.chart.ui.Drawable;
import org.jfree.graphics2d.svg.SVGGraphics2D;
import java.io.ByteArrayInputStream;
import java.io.InputStream;
import java.awt.geom.Rectangle2D;
import java.util.Map;

public class DynamicChartUriResolver implements io.github.openhtmltopdf.extend.FSUriResolver {
    
    private final Map<String, Drawable> chartMap;

    // Pass the map holding your compiled report charts
    public DynamicChartUriResolver(Map<String, Drawable> chartMap) {
        this.chartMap = chartMap;
    }

    @Override
    public String resolveURI(String baseUri, String uri) {
        // Leave string references intact so they hit our stream interceptor below
        return uri;
    }

    /**
     * Helper to render the specified JFreeChart directly into an SVG Input Stream
     */
    public InputStream getChartStream(String uri) {
        if (uri != null && uri.startsWith("chart://")) {
            String chartKey = uri.substring("chart://".length());
            Drawable chart = chartMap.get(chartKey);

            if (chart != null) {
                try {
                    // Set up standard chart point dimensions
                    int width = 727;
                    int height = 330;

                    // Generate clean, mathematical SVG vector strings
                    SVGGraphics2D svg2d = new SVGGraphics2D(width, height);
                    chart.draw(svg2d, new Rectangle2D.Double(0, 0, width, height));
                    String svgXml = svg2d.getSVGElement();

                    // Return a fresh stream of vector code directly to the renderer
                    return new ByteArrayInputStream(svgXml.getBytes("UTF-8"));
                } catch (Exception ex) {
                    throw new RuntimeException("Error streaming vector chart for key: " + chartKey, ex);
                }
            }
        }
        return null;
    }
}


import io.github.openhtmltopdf.pdfboxout.PdfRendererBuilder;
import io.github.openhtmltopdf.svg.LocalStreamSvgImageElementFactory;

// 1. Collect your financial charts in a standard map
Map<String, Drawable> reportCharts = new HashMap<>();
reportCharts.put("liquidAssets", baseProjectChart1);
reportCharts.put("pensionGrowth", baseProjectChart2);

PdfRendererBuilder builder = new PdfRendererBuilder();

// 2. Instantiate our clean resolver context
DynamicChartUriResolver chartResolver = new DynamicChartUriResolver(reportCharts);

// 3. Register a custom user agent to process the chart:// stream keys
builder.useUserAgentCallback(new io.github.openhtmltopdf.util.XRSimpleUserAgent() {
    @Override
    public InputStream openStream(String uri) {
        if (uri != null && uri.startsWith("chart://")) {
            return chartResolver.getChartStream(uri);
        }
        return super.openStream(uri);
    }
});

// 4. Fire off standard PDF compilation tasks
builder.withHtmlFile(htmlInputFile);
builder.toStream(outputPdfStream);
builder.run();



