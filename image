import org.jfree.chart.JFreeChart;
import org.jfree.chart.plot.CategoryPlot;
import org.jfree.chart.plot.XYPlot;
import org.jfree.chart.ui.Drawable;
import java.awt.BasicStroke;
import java.awt.Color;
import java.awt.Graphics2D;
import java.awt.RenderingHints;
import java.awt.image.BufferedImage;
import java.io.ByteArrayOutputStream;
import java.lang.reflect.Method;
import java.util.Base64;
import java.util.HashMap;
import java.util.Map;
import javax.imageio.ImageIO;

public class HighDpiChartExporter {

    public static Map<String, String> convertChartsToBase64(Map<String, Drawable> chartMap, int widthPt, int heightPt) {
        Map<String, String> base64Map = new HashMap<>();
        
        int scale = 3; 
        int renderWidth = widthPt * scale;
        int renderHeight = heightPt * scale;

        for (Map.Entry<String, Drawable> entry : chartMap.entrySet()) {
            try {
                Drawable drawable = entry.getValue();
                JFreeChart jfreeChart = null;

                // 1. Uncover the JFreeChart instance if it's hidden inside your wrapper
                if (drawable instanceof JFreeChart) {
                    jfreeChart = (JFreeChart) drawable;
                } else {
                    // Reflection fallback: Try to look for common getter names in your custom class
                    String[] getterNames = {"getChart", "getJFreeChart", "getPlot"};
                    for (String name : getterNames) {
                        try {
                            Method method = drawable.getClass().getMethod(name);
                            Object result = method.invoke(drawable);
                            if (result instanceof JFreeChart) {
                                jfreeChart = (JFreeChart) result;
                                break;
                            }
                        } catch (Exception ignored) {
                            // Method doesn't exist on this wrapper, try next one
                        }
                    }
                }

                // 2. Apply targeted theme enhancements to ONLY the gridlines and axes
                if (jfreeChart != null) {
                    jfreeChart.setAntiAlias(true);
                    
                    if (jfreeChart.getPlot() instanceof CategoryPlot) {
                        CategoryPlot plot = (CategoryPlot) jfreeChart.getPlot();
                        
                        // Force horizontal gridlines to be distinct and sharp
                        plot.setRangeGridlinesVisible(true);
                        plot.setRangeGridlinePaint(Color.GRAY); // Solid grey line instead of light silver
                        plot.setRangeGridlineStroke(new BasicStroke(1.5f)); // Stronger definition
                        
                        // Make the bottom baseline axis solid and visible
                        plot.setOutlinePaint(Color.DARK_GRAY);
                        plot.setOutlineStroke(new BasicStroke(1.5f));
                        
                    } else if (jfreeChart.getPlot() instanceof XYPlot) {
                        XYPlot plot = (XYPlot) jfreeChart.getPlot();
                        plot.setRangeGridlinesVisible(true);
                        plot.setRangeGridlinePaint(Color.GRAY);
                        plot.setRangeGridlineStroke(new BasicStroke(1.5f));
                        plot.setOutlinePaint(Color.DARK_GRAY);
                    }
                }

                // 3. Render clean High-Res PNG Context (Completely throw away the HighContrastProxy class)
                BufferedImage image = new BufferedImage(renderWidth, renderHeight, BufferedImage.TYPE_INT_RGB);
                Graphics2D g2d = image.createGraphics();

                g2d.setColor(Color.WHITE);
                g2d.fillRect(0, 0, renderWidth, renderHeight);

                g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
                g2d.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_LCD_HRGB);
                g2d.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);
                g2d.setRenderingHint(RenderingHints.KEY_STROKE_CONTROL, RenderingHints.VALUE_STROKE_PURE);

                g2d.scale(scale, scale);

                // Draw the chart layout natively
                java.awt.geom.Rectangle2D area = new java.awt.geom.Rectangle2D.Double(0, 0, widthPt, heightPt);
                drawable.draw(g2d, area);
                g2d.dispose();

                // 4. Output the clean Base64 string
                ByteArrayOutputStream baos = new ByteArrayOutputStream();
                ImageIO.write(image, "png", baos);
                String base64String = Base64.getEncoder().encodeToString(baos.toByteArray());
                
                base64Map.put(entry.getKey(), base64String);
            } catch (Exception e) {
                throw new RuntimeException("Error customizing gridlines for chart key: " + entry.getKey(), e);
            }
        }
        return base64Map;
    }
}
