import org.jfree.chart.ui.Drawable;
import org.jfree.graphics2d.svg.SVGGraphics2D;
import org.jfree.graphics2d.svg.SVGUnits;
import java.awt.geom.Rectangle2D;
import java.util.Base64;

public class VectorChartExporter {

    public static String convertDrawableToSvgBase64(Drawable drawable, int targetWidth, int targetHeight) {
        try {
            // 1. Create a Scalable Vector Graphics canvas instead of a pixel buffer
            SVGGraphics2D svg2d = new SVGGraphics2D(targetWidth, targetHeight);

            // 2. Direct your chart to draw its mathematical shapes onto the vector canvas
            Rectangle2D area = new Rectangle2D.Double(0, 0, targetWidth, targetHeight);
            drawable.draw(svg2d, area);

            // 3. Extract the raw SVG XML string text (e.g., <svg><rect.../><text...></svg>)
            // We use standard PT units to align perfectly with OpenHTMLtoPDF
            String svgElement = svg2d.getSVGElement(null, true, null, null, SVGUnits.PT);

            // 4. Encode the clean XML text to a Base64 string for safe HTML injection
            return Base64.getEncoder().encodeToString(svgElement.getBytes("UTF-8"));

        } catch (Exception e) {
            throw new RuntimeException("Failed compiling high-grade vector SVG chart matrix", e);
        }
    }
}// Pass your strict target points directly
String vectorSvgBase64 = VectorChartExporter.convertDrawableToSvgBase64((Drawable) baseProjectChart, 727, 330);

model.addAttribute("vectorChart", vectorSvgBase64);


<div class="chart-vector-wrapper" style="width: 727pt; height: 330pt; margin: 0 auto; text-align: center;">

