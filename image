import org.jfree.chart.ui.Drawable;
import java.awt.Color;
import java.awt.Graphics2D;
import java.awt.RenderingHints;
import java.awt.image.BufferedImage;
import java.io.ByteArrayOutputStream;
import java.util.Base64;
import javax.imageio.ImageIO;

public class PristineChartExporter {

    public static String convertDrawableToBase64(Drawable drawable, int targetWidth, int targetHeight) {
        try {
            // 1. Double the pixel size for crisp PDF display
            int scaleFactor = 2;
            int imageWidth = targetWidth * scaleFactor;
            int imageHeight = targetHeight * scaleFactor;

            // 2. High-contrast RGB background setup
            BufferedImage image = new BufferedImage(imageWidth, imageHeight, BufferedImage.TYPE_INT_RGB);
            Graphics2D g2d = image.createGraphics();

            g2d.setColor(Color.WHITE);
            g2d.fillRect(0, 0, imageWidth, imageHeight);

            // 3. THE SHARPNESS FIX: Explicitly isolate text vs graphics anti-aliasing
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            
            // Forces the font renderer to use sub-pixel LCD smoothing (makes text sharp)
            g2d.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_LCD_HRGB);
            
            // Clean up vector lines and borders
            g2d.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);
            g2d.setRenderingHint(RenderingHints.KEY_INTERPOLATION, RenderingHints.VALUE_INTERPOLATION_BICUBIC);
            g2d.setRenderingHint(RenderingHints.KEY_STROKE_CONTROL, RenderingHints.VALUE_STROKE_PURE);

            // 4. Paint directly to the high-res bounding box
            // If your custom chart supports a scale/DPI factor, invoke it here.
            // Otherwise, let it fill the high-density space cleanly:
            java.awt.geom.Rectangle2D area = new java.awt.geom.Rectangle2D.Double(0, 0, imageWidth, imageHeight);
            drawable.draw(g2d, area);
            
            g2d.dispose();

            // 5. Compress to clean PNG
            ByteArrayOutputStream baos = new ByteArrayOutputStream();
            ImageIO.write(image, "png", baos);
            return Base64.getEncoder().encodeToString(baos.toByteArray());

        } catch (Exception e) {
            throw new RuntimeException("Failed compiling pristine chart layout", e);
        }
    }
}


