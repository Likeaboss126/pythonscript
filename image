import io.github.openhtmltopdf.extend.FSImage;
import io.github.openhtmltopdf.extend.ReplacedElement;
import io.github.openhtmltopdf.extend.ReplacedElementFactory;
import io.github.openhtmltopdf.extend.UserAgentCallback;
import io.github.openhtmltopdf.render.BlockBox;
import io.github.openhtmltopdf.render.RenderingContext;
import io.github.openhtmltopdf.svg.AmazonSVGImage; // Built-in high-performance vector container
import org.w3c.dom.Element;
import org.jfree.chart.ui.Drawable;
import org.jfree.graphics2d.svg.SVGGraphics2D;
import java.io.ByteArrayInputStream;
import java.io.InputStream;
import java.awt.geom.Rectangle2D;
import java.util.Map;

public class DynamicChartImageFactory implements ReplacedElementFactory {
    
    private final ReplacedElementFactory baseFactory;
    private final Map<String, Drawable> chartMap;

    public DynamicChartImageFactory(ReplacedElementFactory baseFactory, Map<String, Drawable> chartMap) {
        this.baseFactory = baseFactory;
        this.chartMap = chartMap;
    }

    @Override
    public ReplacedElement createReplacedElement(RenderingContext context, BlockBox box, 
                                                 UserAgentCallback uac, int cssWidth, int cssHeight) {
        Element e = box.getElement();
        if (e == null) return null;

        // Check if this is an image tag requesting a dynamic chart asset
        if ("img".equalsIgnoreCase(e.getNodeName())) {
            String src = e.getAttribute("src");
            
            if (src != null && src.startsWith("chart://")) {
                String chartKey = src.substring("chart://".length());
                Drawable chart = chartMap.get(chartKey);

                if (chart != null) {
                    try {
                        // 1. Convert target layout sizing from points to standard units
                        int width = cssWidth > 0 ? cssWidth : 727;
                        int height = cssHeight > 0 ? cssHeight : 330;

                        // 2. Generate pure mathematical vector definitions using JFreeSVG
                        SVGGraphics2D svg2d = new SVGGraphics2D(width, height);
                        chart.draw(svg2d, new Rectangle2D.Double(0, 0, width, height));
                        String svgXml = svg2d.getSVGElement();

                        // 3. Convert the string directly to an input stream context
                        InputStream svgStream = new ByteArrayInputStream(svgXml.getBytes("UTF-8"));

                        // 4. Pass the stream directly to OpenHTMLtoPDF's native SVG layout painter
                        FSImage svgImage = AmazonSVGImage.load(svgStream, width, height, true);
                        
                        // Wrap it up neatly for the rendering engine canvas
                        return new io.github.openhtmltopdf.render.FSImageReplacedElement(svgImage);
                        
                    } catch (Exception ex) {
                        throw new RuntimeException("Failed processing native chart stream key: " + chartKey, ex);
                    }
                }
            }
        }

        // Fall back seamlessly to normal processing for ordinary images
        return this.baseFactory.createReplacedElement(context, box, uac, cssWidth, cssHeight);
    }

    @Override
    public void reset() { this.baseFactory.reset(); }

    @Override
    public void remove(Element e) { this.baseFactory.remove(e); }
}



