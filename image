import org.jfree.chart.ui.Drawable;
import java.awt.Color;
import java.awt.Graphics2D;
import java.awt.RenderingHints;
import java.awt.geom.AffineTransform;
import java.awt.geom.Rectangle2D;
import java.awt.image.BufferedImage;
import java.io.ByteArrayOutputStream;
import java.util.Base64;
import javax.imageio.ImageIO;

public class SharpChartExporter {

    public static String convertDrawableToBase64(Drawable drawable, int targetWidth, int targetHeight) {
        try {
            // 1. Maintain a solid 2x scale for high density
            double scale = 2.0;
            int imageWidth = (int) (targetWidth * scale);
            int imageHeight = (int) (targetHeight * scale);

            // 2. CRITICAL CHANGE: Use TYPE_INT_RGB instead of ARGB.
            // ARGB can wash out thin lines due to semi-transparency interpolation. 
            // RGB locks down crisp, full-contrast pixel colors.
            BufferedImage image = new BufferedImage(imageWidth, imageHeight, BufferedImage.TYPE_INT_RGB);
            Graphics2D g2d = image.createGraphics();

            // 3. Flood the background with pure white (Required for non-transparent RGB images)
            g2d.setColor(Color.WHITE);
            g2d.fillRect(0, 0, imageWidth, imageHeight);

            // 4. CRITICAL CONTRAST & SHARPNESS HINTS
            g2d.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            g2d.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON);
            g2d.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);
            
            // FIX FOR TEXT BLUR: Disable fractional metrics to keep font edges snapped to pixel grids
            g2d.setRenderingHint(RenderingHints.KEY_FRACTIONALMETRICS, RenderingHints.VALUE_FRACTIONALMETRICS_OFF);
            
            // FIX FOR THIN LINES: Force pure normalization so thin 1px lines don't blend into gray blurs
            g2d.setRenderingHint(RenderingHints.KEY_STROKE_CONTROL, RenderingHints.VALUE_STROKE_NORMALIZE);

            // 5. Apply the scaling matrix
            AffineTransform oldTransform = g2d.getTransform();
            g2d.scale(scale, scale);

            // 6. Draw the chart layout
            Rectangle2D area = new Rectangle2D.Double(0, 0, targetWidth, targetHeight);
            drawable.draw(g2d, area);

            // Clean up
            g2d.setTransform(oldTransform);
            g2d.dispose();

            // 7. Compress down into a punchy Base64 PNG payload
            ByteArrayOutputStream baos = new ByteArrayOutputStream();
            ImageIO.write(image, "png", baos);
            return Base64.getEncoder().encodeToString(baos.toByteArray());

        } catch (Exception e) {
            throw new RuntimeException("Failed compiling sharp high-contrast chart matrix", e);
        }
    }
}



img {
    /* Prevents the rendering engine from fuzzing up pixel edges when drawing the chart box */
    image-rendering: -webkit-optimize-contrast; /* Safari / OpenHTML Engine */
    image-rendering: crisp-edges;
    image-rendering: pixelated;
    
    /* Strict layout lock as requested */
    width: 727pt !important;
    height: 330pt !important;
    display: block;
    margin: 0 auto;
}
