String rawSvgString = VectorChartExporter.convertDrawableToRawSvg((Drawable) baseProjectChart, 727, 330);
model.addAttribute("chartSvg", rawSvgString);


import org.jfree.chart.ui.Drawable;
import org.jfree.graphics2d.svg.SVGGraphics2D;
import java.awt.RenderingHints;
import java.awt.geom.Rectangle2D;

public class VectorChartExporter {

    public static String convertDrawableToRawSvg(Drawable drawable, int targetWidth, int targetHeight) {
      try {
            SVGGraphics2D svg2d = new SVGGraphics2D(targetWidth, targetHeight);
            svg2d.setRenderingHint(RenderingHints.KEY_FRACTIONALMETRICS, RenderingHints.VALUE_FRACTIONALMETRICS_ON);
            svg2d.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_ON);

            Rectangle2D area = new Rectangle2D.Double(0, 0, targetWidth, targetHeight);
            drawable.draw(svg2d, area);

            // 1. Get the raw XML string
            String svgElement = svg2d.getSVGElement(); 

            // 2. Encode it into a Base64 string to completely hide the raw XML text from the PDF parser
            return Base64.getEncoder().encodeToString(svgElement.getBytes("UTF-8"));

        } catch (Exception e) {
            throw new RuntimeException("Failed compiling vector SVG string", e);
        }
    }
}

