import java.io.OutputStream;
import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;

public class PdfBoxArtifactFixer {

    private static final List<String> PEN_START = Arrays.asList("m", "re");
    private static final List<String> PEN_END = Arrays.asList("s", "S", "f", "F", "b", "B");

   PDPage page = document.getPage(0);
            PDFStreamParser parser = new PDFStreamParser(page);
            
            List<Object> tokens = new ArrayList<>();
            Object token;
            
            while ((token = parser.parseNextToken()) != null) {
                tokens.add(token);
            }

            List<Object> newTokens = new ArrayList<>();

            for (Object current : tokens) {
                if (current instanceof Operator op) {
                    String name = op.getName();

                    if (PEN_OPERATORS.contains(name)) {
                        // 🛠️ FIX: Drop the pen operator completely from the stream.
                        // This prevents Jasper's borders from triggering PAC errors.
                        continue; 
                    }
                }
                newTokens.add(current);
            }

            // Write back the completely safe token stream
            PDStream updatedStream = new PDStream(document);
            try (OutputStream os = updatedStream.createOutputStream()) {
                new ContentStreamWriter(os).writeTokens(newTokens);
            }
            page.setContents(updatedStream);
}
